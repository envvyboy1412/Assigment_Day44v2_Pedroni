# Supabase — https://supabase.com — run supabase/schema.sql in SQL Editor
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_key

# Optional: country code + number for WhatsApp from contact form (e.g. 6281234567890)
# NEXT_PUBLIC_WHATSAPP_NUMBER=

# Vercel: Project Settings → Environment Variables → paste the same keys for Production/Preview.
# Create an admin user in Supabase Authentication (Email) after deploy.
# If product images use Supabase Storage, add your project host to next.config.ts images.remotePatterns
# or keep using public HTTPS image URLs in the admin form.
